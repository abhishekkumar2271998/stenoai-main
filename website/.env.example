# Credentials for the marketing website (Vite). Copy to `.env` and fill in real values.
# This file is committed as documentation; `.env` is gitignored.
# Vite only exposes vars prefixed with VITE_ to client code, inlined at build time.

# PostHog product-analytics project key (phc_...)
VITE_POSTHOG_KEY=your-posthog-project-key
VITE_POSTHOG_HOST=https://us.i.posthog.com
