# Credentials for the Electron app. Copy to `.env` and fill in real values.
# This file is committed as documentation; `.env` is gitignored.

# PostHog product-analytics project key (phc_...)
POSTHOG_API_KEY=your-posthog-project-key

# Google Calendar OAuth2 client (Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft/Outlook Calendar OAuth2 client ID (Azure App registration, PKCE public client)
OUTLOOK_CLIENT_ID=your-outlook-client-id
